const handleContactFormSubmit = async (formData) => {
    try {
        // 1. Send POST request to backend
        const response = await fetch(`${API_BASE_URL}/contact`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData)
        });

        // 2. Parse JSON response
        const data = await response.json();

        // 3. Check if successful
        if (response.ok) {
            alert('✅ Thank you! We will contact you soon.');
            return true;
        } else {
            alert('❌ Error: ' + data.error);
            return false;
        }
    } catch (error) {
        // 4. Handle network errors
        console.error('Contact form error:', error);
        alert('❌ Network error. Please try again.');
        return false;
    }
};
```

**How it works:**
1. User fills form and clicks submit
2. JavaScript captures form data
3. Sends HTTP POST request to backend
4. Backend processes and saves to database
5. Backend sends response back
6. Frontend shows success/error message

