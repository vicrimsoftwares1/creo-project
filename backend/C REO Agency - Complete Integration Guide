```javascript
// API Configuration
const API_BASE_URL = 'http://localhost:5000/api';

// ============================================
// CONTACT FORM HANDLER
// ============================================
document.addEventListener('DOMContentLoaded', function() {
    
    // Get all CTA buttons that should open contact modal
    const ctaButtons = document.querySelectorAll('.cta-button, .cta-white');
    const contactSection = document.getElementById('contact');
    
    // Handle contact form submission
    const handleContactFormSubmit = async (formData) => {
        try {
            const response = await fetch(`${API_BASE_URL}/contact`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(formData)
            });

            const data = await response.json();

            if (response.ok) {
                alert('✅ Thank you! We will contact you soon.');
                return true;
            } else {
                alert('❌ Error: ' + (data.error || 'Failed to submit form'));
                return false;
            }
        } catch (error) {
            console.error('Contact form error:', error);
            alert('❌ Network error. Please try again.');
            return false;
        }
    };

    // Add click handler to CTA buttons to scroll to contact
    ctaButtons.forEach(button => {
        button.addEventListener('click', (e) => {
            e.preventDefault();
            contactSection.scrollIntoView({ behavior: 'smooth' });
            // Optional: Open a modal here
        });
    });

    // ============================================
    // NEWSLETTER SUBSCRIPTION
    // ============================================
    const handleNewsletterSubmit = async (email, name = '') => {
        try {
            const response = await fetch(`${API_BASE_URL}/newsletter/subscribe`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ email, name })
            });

            const data = await response.json();

            if (response.ok) {
                alert('✅ Successfully subscribed to newsletter!');
                return true;
            } else {
                alert('❌ ' + (data.error || 'Failed to subscribe'));
                return false;
            }
        } catch (error) {
            console.error('Newsletter error:', error);
            alert('❌ Network error. Please try again.');
            return false;
        }
    };

    // ============================================
    // LOAD PORTFOLIO ITEMS
    // ============================================
    const loadPortfolio = async () => {
        try {
            const response = await fetch(`${API_BASE_URL}/portfolio/featured`);
            const data = await response.json();

            if (response.ok && data.success) {
                displayPortfolio(data.data);
            }
        } catch (error) {
            console.error('Portfolio load error:', error);
        }
    };

    const displayPortfolio = (portfolioItems) => {
        const portfolioGrid = document.querySelector('.portfolio-grid');
        
        if (!portfolioGrid || portfolioItems.length === 0) return;

        portfolioGrid.innerHTML = portfolioItems.map(item => `
            <div class="portfolio-item" style="background-image: url('${API_BASE_URL.replace('/api', '')}${item.images[0] || ''}')">
                <div class="portfolio-content">
                    <h3>${item.title}</h3>
                    <p>${item.description}</p>
                    ${item.pdfFile ? `<a href="${API_BASE_URL.replace('/api', '')}${item.pdfFile}" target="_blank">View Portfolio</a>` : ''}
                </div>
            </div>
        `).join('');
    };

    // ============================================
    // LOAD TESTIMONIALS
    // ============================================
    const loadTestimonials = async () => {
        try {
            const response = await fetch(`${API_BASE_URL}/testimonials?featured=true`);
            const data = await response.json();

            if (response.ok && data.success) {
                displayTestimonials(data.data);
            }
        } catch (error) {
            console.error('Testimonials load error:', error);
        }
    };

    const displayTestimonials = (testimonials) => {
        const testimonialSlider = document.querySelector('.testimonial-slider');
        
        if (!testimonialSlider || testimonials.length === 0) return;

        // Display first testimonial (you can add slider logic here)
        const testimonial = testimonials[0];
        testimonialSlider.innerHTML = `
            <div class="testimonial">
                <p>"${testimonial.content}"</p>
                <div class="testimonial-author">${testimonial.name}</div>
                <div class="testimonial-role">${testimonial.role}${testimonial.company ? ', ' + testimonial.company : ''}</div>
            </div>
        `;
    };

    // ============================================
    // ANALYTICS TRACKING
    // ============================================
    const trackEvent = async (event, metadata = {}) => {
        try {
            await fetch(`${API_BASE_URL}/analytics/track`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    event,
                    page: window.location.pathname,
                    sessionId: getSessionId(),
                    metadata
                })
            });
        } catch (error) {
            console.error('Analytics error:', error);
        }
    };

    const getSessionId = () => {
        let sessionId = sessionStorage.getItem('sessionId');
        if (!sessionId) {
            sessionId = 'session-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
            sessionStorage.setItem('sessionId', sessionId);
        }
        return sessionId;
    };

    // Track page view
    trackEvent('page_view');

    // Track button clicks
    document.querySelectorAll('.cta-button, .secondary-button').forEach(button => {
        button.addEventListener('click', () => {
            trackEvent('button_click', { button: button.textContent });
        });
    });

    // ============================================
    // INITIALIZE
    // ============================================
    loadPortfolio();
    loadTestimonials();
});
```

